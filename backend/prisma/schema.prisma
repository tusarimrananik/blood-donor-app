generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Request {
  id             String   @id @default(uuid())
  requesterName  String
  requesterPhone String
  bloodGroup     String
  message        String?
  area           String?
  hospital       String?
  urgency        String   @default("STANDARD")
  status         String   @default("OPEN")
  targetDonorId  String?
  targetDonor    Donor?   @relation("TargetedRequests", fields: [targetDonorId], references: [id], onDelete: SetNull)
  donorId        String?
  donor          Donor?   @relation("MatchedDonorRequests", fields: [donorId], references: [id], onDelete: SetNull)
  createdById    String?
  createdBy      Donor?   @relation("CreatedRequests", fields: [createdById], references: [id], onDelete: SetNull)
  responses      RequestResponse[]
  notifications  Notification[]
  createdAt      DateTime @default(now())

  @@index([donorId])
  @@index([targetDonorId])
  @@index([requesterPhone])
  @@index([createdById])
  @@index([donorId, requesterPhone, createdAt])
  @@map("requests")
}

model Donor {
  id           String   @id @default(uuid())
  name         String
  phone        String   @unique
  email        String   @unique
  bloodGroup   String
  area         String
  lastDonated  DateTime?
  passwordHash String?
  gender       String?
  dateOfBirth  DateTime?
  profileImage String?
  canDonate    Boolean  @default(true)

  // PostGIS Point (lon, lat), SRID 4326
  location Unsupported("geometry(Point, 4326)")
  requestsMatched  Request[]         @relation("MatchedDonorRequests")
  requestsCreated  Request[]         @relation("CreatedRequests")
  requestsTargeted Request[]         @relation("TargetedRequests")
  requestResponses RequestResponse[]
  receivedNotifications Notification[] @relation("RecipientNotifications")
  sentNotifications     Notification[] @relation("ActorNotifications")
  pushTokens            PushToken[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("donors")
}

model RequestResponse {
  id         String   @id @default(uuid())
  requestId  String
  donorId    String
  createdAt  DateTime @default(now())
  request    Request  @relation(fields: [requestId], references: [id], onDelete: Cascade)
  donor      Donor    @relation(fields: [donorId], references: [id], onDelete: Cascade)

  @@unique([requestId, donorId])
  @@index([requestId])
  @@index([donorId])
  @@map("request_responses")
}

model Notification {
  id          String   @id @default(uuid())
  recipientId String
  actorId     String?
  requestId   String?
  type        String
  title       String
  body        String
  readAt      DateTime?
  createdAt   DateTime @default(now())
  recipient   Donor    @relation("RecipientNotifications", fields: [recipientId], references: [id], onDelete: Cascade)
  actor       Donor?   @relation("ActorNotifications", fields: [actorId], references: [id], onDelete: SetNull)
  request     Request? @relation(fields: [requestId], references: [id], onDelete: SetNull)

  @@index([recipientId, createdAt])
  @@index([recipientId, readAt])
  @@index([requestId])
  @@map("notifications")
}

model PushToken {
  id         String   @id @default(uuid())
  donorId    String
  token      String   @unique
  platform   String
  disabledAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  donor      Donor    @relation(fields: [donorId], references: [id], onDelete: Cascade)

  @@index([donorId, disabledAt])
  @@map("push_tokens")
}
